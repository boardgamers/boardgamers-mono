    "dompurify": "^2.3.1",
    "eventemitter3": "^4.0.7",
    "lodash": "npm:lodash-es@^4.17.21",
    "marked": "^3.0.2",
    "nprogress": "^0.2.0",
    "remove-markdown": "^0.3.0",
    "svelte": "^5.56.4",
    "type-fest": "^2.1.0"
  },
  "devDependencies": {
    "@alasano/svelte-fast-check": "0.4.6-fork.2",
    "@bgs/models": "workspace:*",
    "@sveltejs/adapter-node": "^5.5.7",
