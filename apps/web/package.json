    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-svelte": "^3.9.1",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.3.1",
