{
  "name": "@bgs/game-server",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "batch-replay": "node --env-file-if-exists=.env --env-file-if-exists=.env.${NODE_ENV} scripts/batch-replay.ts",
    "dev": "tsx watch --env-file-if-exists=.env --env-file-if-exists=.env.${NODE_ENV} server.ts",
    "fmt": "oxfmt",
    "fmt-check": "oxfmt --check",
    "lint": "oxlint --fix",
    "lint-check": "oxlint",
    "start": "node --env-file-if-exists=.env --env-file-if-exists=.env.${NODE_ENV} server.ts",
    "test": "node --test 'app/**/*.spec.ts'",
    "tsc": "tsgo --noEmit"
  },
  "dependencies": {
    "@bgs/models": "workspace:*",
    "@bgs/utils": "workspace:*",
    "decache": "^4.6.0",
    "fs-extra": "^9.0.0",
    "http-errors": "^1.7.3",
    "jsonwebtoken": "^8.5.1",
    "koa": "^2.11.0",
    "koa-bodyparser": "^4.3.0",
    "koa-compress": "^4.0.0",
    "koa-morgan": "^1.0.1",
    "koa-router": "^8.0.8",
    "mongo-locks": "^3.1.2",
    "mongodb": "^7.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^8.1.0",
    "@types/http-errors": "^1.6.3",
    "@types/jsonwebtoken": "^8.3.9",
    "@types/koa": "^2.11.3",
    "@types/koa-bodyparser": "^4.3.0",
    "@types/koa-compress": "^2.0.9",
    "@types/koa-morgan": "^1.0.4",
    "@types/koa-router": "^7.4.0",
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260307.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0"
  }
}
